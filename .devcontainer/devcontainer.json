{
  "name": "AI Assistant Development Workspace",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "workspace",
  // Fixed: Points straight to your real path inside the container
  "workspaceFolder": "/aiassistant", 
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "remoteUser": "root"
}