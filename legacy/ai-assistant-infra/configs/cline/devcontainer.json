{
  "name": "AI Assistant Development Workspace",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "workspace",
  // Fixed: Points straight to your real path inside the container
  "workspaceFolder": "/aiassistant/agentic/src", 
  "customizations": {
    "vscode": {
      "extensions": [
        "saoudrizwan.claude-dev"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "remoteUser": "root"
}
